{
  "name": "studyspark-adk",
  "version": "1.0.0",
  "description": "StudySpark AI backend — multi-agent personalised learning powered by Google ADK",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "serve": "tsx src/index.ts",
    "dev": "adk web",
    "adk:run": "adk run agent.ts",
    "adk:run-server": "npm run serve",
    "test:local": "tsx scripts/test.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/adk": "^0.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@google/adk-devtools": "^0.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
}
