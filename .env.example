# Google Gemini API key (from Google AI Studio: aistudio.google.com)
GOOGLE_API_KEY=your_gemini_api_key_here

# Shared secret between this server and the Cloudflare Worker
INTERNAL_API_KEY=your_internal_api_key_here

# Cloudflare Worker base URL
WORKER_BASE_URL=https://api.studyspark.app

# HTTP server port (Cloud Run expects 8080)
PORT=8080
